# Копируйте в `.env` при необходимости (файл `.env` не коммитить с секретами).

# Origin backend без завершающего слэша. Если пусто — в dev используется прокси Vite на /employee-progress
# VITE_API_BASE_URL=http://localhost:8008

# users-service (логин). Если пусто — в dev прокси Vite: /users → http://localhost:8001
# VITE_USERS_API_BASE_URL=http://localhost:8001

# claim с company_id в access token (как в users-service / security.jwt.company-id-claim)
# VITE_JWT_COMPANY_CLAIM=company_id

# claim с employee_id (для ИПР и контекста «текущий сотрудник»)
# VITE_JWT_EMPLOYEE_CLAIM=employee_id

# id компании в БД — fallback, если в JWT нет company_id (чисто локальная вёрстка)
# VITE_DEV_COMPANY_ID=1
